{
  "name": "nexus-directory",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@astrojs/vercel": "^11.0.3",
    "@nanostores/react": "^1.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-virtual": "^3.14.8",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "algoliasearch": "4",
    "astro": "^7.0.6",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.25.0",
    "nanostores": "^1.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-intersection-observer": "^10.1.0",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.1",
    "oxlint": "^1.75.0",
    "prettier": "^3.9.6",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "src/**/*.css": [
      "prettier --write"
    ]
  }
}
