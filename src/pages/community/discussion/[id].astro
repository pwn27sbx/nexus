---
import Layout from '../../../layouts/Layout.astro';
import { API_BASE_URL } from '../../../utils/constants';

const { id } = Astro.params;

// Fetch the discussion data via SSR
let discussion: any = null;
let error = null;

try {
  const res = await fetch(`${API_BASE_URL}/api/discussions/${id}`);
  if (res.ok) {
    discussion = await res.json();
  } else {
    error = 'Discussion not found';
  }
} catch (e) {
  error = 'Error loading discussion';
}
---

<Layout>
  <main class="min-h-screen bg-[#f8f9fa] dark:bg-[#0a0a0a] text-black dark:text-white transition-colors duration-300">
    <div class="fixed inset-0 pointer-events-none z-0">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,#e5e7eb,transparent_80%)] dark:bg-[radial-gradient(ellipse_at_top,#1f2937,transparent_80%)] opacity-60"></div>
    </div>
    
    <div class="relative z-10 max-w-4xl mx-auto px-4 py-20">
      <a href="/" class="inline-flex items-center gap-2 text-sm text-[rgba(100,100,100,0.8)] dark:text-[rgba(200,200,200,0.8)] hover:text-black dark:hover:text-white mb-8 transition-colors">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Back to Community
      </a>

      {error ? (
        <div class="text-center py-20">
          <h1 class="text-2xl font-bold mb-4">{error}</h1>
        </div>
      ) : discussion ? (
        <article class="p-8 sm:p-12 rounded-[2rem] shadow-xl backdrop-blur-xl" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1);">
          <div class="mb-8 border-b pb-8 border-[rgba(255,255,255,0.1)]">
            <span class="inline-block px-3 py-1 text-xs font-bold uppercase tracking-wider rounded-full mb-4" style="background: rgba(168,85,247,0.2); color: #a855f7;">
              {discussion.category}
            </span>
            <h1 class="text-3xl sm:text-5xl font-extrabold font-display leading-tight mb-6">
              {discussion.title}
            </h1>
            
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full overflow-hidden bg-purple-500/20 flex items-center justify-center font-bold text-xl text-purple-500">
                  {discussion.author?.avatar ? (
                    <img src={discussion.author.avatar} alt="" class="w-full h-full object-cover" />
                  ) : (
                    (discussion.author?.nickname || 'U').charAt(0).toUpperCase()
                  )}
                </div>
                <div>
                  <div class="font-bold text-lg">{discussion.author?.nickname || 'Anonymous'}</div>
                  <div class="text-sm opacity-60">Posted on {new Date(discussion.createdAt).toLocaleDateString()}</div>
                </div>
              </div>
              <div class="flex items-center gap-2 px-4 py-2 rounded-full" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);">
                <span class="font-bold">{discussion.upvotes || 0}</span>
                <span class="opacity-60 text-sm">Upvotes</span>
              </div>
            </div>
          </div>
          
          <div class="prose dark:prose-invert max-w-none prose-lg">
            <p>{discussion.summary}</p>
            {/* Real implementation would render discussion.content rich text here */}
          </div>
        </article>
      ) : (
        <div class="text-center py-20">Loading...</div>
      )}

      {discussion && (
        <section class="mt-12">
          <h3 class="text-2xl font-bold mb-6 font-display">Comments</h3>
          <div class="p-8 rounded-[2rem] text-center" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
            <p class="opacity-60 mb-4">Interactive comment section goes here.</p>
            <button class="px-6 py-2.5 rounded-full font-bold transition-transform hover:scale-105" style="background: linear-gradient(135deg, #a855f7, #6366f1); color: white;">
              Login to Comment
            </button>
          </div>
        </section>
      )}
    </div>
  </main>
</Layout>
