---
import '../../../styles/global.css';
import { API_BASE_URL } from '../../../utils/constants';
import ToolDetailView from '../../../components/ToolDetailView.tsx'; // Actually we need a collection view, let's create a new component or just render the ListCards here.
import BentoCard from '../../../components/BentoCard.tsx';

// Enable SSR
export const prerender = false;

const { userId, collectionSlug } = Astro.params;

let collection = null;
let user = null;
let tools = [];

try {
  // Fetch user to get their collections
  const userRes = await fetch(`${API_BASE_URL}/api/users/${userId}?depth=1`);
  if (userRes.ok) {
    user = await userRes.json();

    // Find the specific collection
    if (user.collections) {
      collection = user.collections.find((c: any) => c.slug === collectionSlug);

      if (collection && collection.isPublic && collection.tools) {
        tools = collection.tools;
      }
    }
  }
} catch (e) {
  console.error('Error fetching collection:', e);
}

if (!collection || !collection.isPublic) {
  return Astro.redirect('/404');
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{collection.name} by {user?.nickname} — Nexus Directory</title>
    <meta
      name="description"
      content={`A public collection of tools curated by ${user?.nickname}`}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800;0,14..32,900;1,14..32,400&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        try {
          var isDark = false;
          var stored = localStorage.getItem('nexus-theme');
          if (stored === 'dark' || stored === 'light') {
            isDark = stored === 'dark';
          } else {
            isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          }
          if (isDark) {
            document.documentElement.classList.add('dark');
          } else {
            document.documentElement.classList.remove('dark');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body
    class="bg-[#f0f4f8] text-[#0f172a] dark:bg-[#050505] dark:text-[#f8fafc] min-h-screen transition-colors duration-300 antialiased"
  >
    <header
      class="sticky top-0 z-50 px-6 py-4 flex items-center justify-between"
      style="background: rgba(5,5,5,0.8); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.05);"
    >
      <a
        href="/"
        class="flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium transition-colors hover:bg-white/10"
      >
        ← Back to Nexus
      </a>
    </header>

    <main class="max-w-7xl mx-auto px-6 py-12">
      <div class="mb-12 text-center">
        <h1 class="text-4xl font-bold mb-4">{collection.name}</h1>
        <p class="text-xl opacity-70">Curated by {user?.nickname}</p>
        <p class="mt-4 opacity-50">{tools.length} tools</p>
      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 auto-rows-[280px]"
      >
        {
          tools.map((tool: any, index: number) => (
            <BentoCard client:load tool={tool} index={index} />
          ))
        }
      </div>

      {
        tools.length === 0 && (
          <div class="text-center opacity-50 py-20">This collection is empty.</div>
        )
      }
    </main>
  </body>
</html>
