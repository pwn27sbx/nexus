---
import Directory from "../components/Directory.tsx";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Nexus — Ultimate Spatial Gallery Directory</title>
    <meta name="description" content="Next-generation immersive web directory & resource library. Discover the best tools across Design, Development, AI, and more." />
    <meta name="keywords" content="web directory, tools, resources, design, development, AI, productivity, gallery, spatial" />
    <meta name="theme-color" content="#c7d7f5" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0d0d1a" media="(prefers-color-scheme: dark)" />
    <meta name="color-scheme" content="dark light" />
    <meta property="og:title" content="Nexus — Ultimate Spatial Gallery Directory" />
    <meta property="og:description" content="Next-generation immersive web directory & resource library." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://images.unsplash.com/photo-1618761714954-0b8cd0026356?q=80&w=1200&auto=format&fit=crop" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Nexus — Ultimate Spatial Gallery Directory" />
    <meta name="twitter:description" content="Next-generation immersive web directory & resource library." />
    <meta name="twitter:image" content="https://images.unsplash.com/photo-1618761714954-0b8cd0026356?q=80&w=1200&auto=format&fit=crop" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800;0,14..32,900;1,14..32,400&display=swap" rel="stylesheet" />
    <script is:inline>
      (function() {
        try {
          var isDark = false;
          var saved = localStorage.getItem('nexus-theme');
          if (saved) {
            isDark = saved === 'dark';
          } else {
            isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          }
          if (isDark) {
            document.documentElement.classList.add('dark');
            document.documentElement.style.background = 'linear-gradient(135deg, #0d0d1a 0%, #111128 50%, #16102e 100%)';
          } else {
            document.documentElement.classList.remove('dark');
            document.documentElement.style.background = 'linear-gradient(135deg, #c7d7f5 0%, #d5c8f0 50%, #e8d5f5 100%)';
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="spatial-bg overflow-x-hidden">
    <Directory client:load />
  </body>
</html>
