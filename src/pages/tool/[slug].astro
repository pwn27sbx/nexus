---
import "../../styles/global.css";
import { ClientRouter } from 'astro:transitions';
import ToolDetailView from "../../components/ToolDetailView.tsx";
import { API_BASE_URL } from "../../utils/constants";

// Enable SSR for this route
export const prerender = false;

const { slug } = Astro.params;

// Fetch the tool from Payload CMS using the REST API
let tool = null;

try {
  const isNumeric = /^\d+$/.test(slug);
  const query = isNumeric
    ? `where[id][equals]=${slug}`
    : `where[slug][equals]=${slug}`;

  // We search for the tool by its auto-generated slug or ID
  const response = await fetch(`${API_BASE_URL}/api/tools?${query}&depth=1`);
  const data = await response.json();
  
  if (data.docs && data.docs.length > 0) {
    tool = data.docs[0];
  }
} catch (e) {
  console.error("Error fetching tool details:", e);
}

if (!tool) {
  // If not found, return 404
  return Astro.redirect('/404');
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{tool.name} — Nexus Directory</title>
    <meta name="description" content={tool.description} />
    <meta property="og:title" content={`${tool.name} — Nexus Directory`} />
    <meta property="og:description" content={tool.description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={tool.screenshotUrl || "https://images.unsplash.com/photo-1618761714954-0b8cd0026356?q=80&w=1200&auto=format&fit=crop"} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${tool.name} — Nexus Directory`} />
    <meta name="twitter:description" content={tool.description} />
    <meta name="twitter:image" content={tool.screenshotUrl || "https://images.unsplash.com/photo-1618761714954-0b8cd0026356?q=80&w=1200&auto=format&fit=crop"} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800;0,14..32,900;1,14..32,400&display=swap" rel="stylesheet" />
    <ClientRouter />
    <script is:inline>
      (function() {
        try {
          var isDark = false;
          var stored = localStorage.getItem("nexus-theme");
          if (stored === "dark" || stored === "light") {
            isDark = stored === "dark";
          } else {
            isDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          }
          if (isDark) {
            document.documentElement.classList.add("dark");
          } else {
            document.documentElement.classList.remove("dark");
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="spatial-bg overflow-x-hidden min-h-screen transition-colors duration-300 antialiased">
    <ToolDetailView client:load tool={tool} />
  </body>
</html>
