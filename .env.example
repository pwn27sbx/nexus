# Frontend Environment Variables
# Copy this file to .env and fill in your values

# Public Algolia credentials (safe to expose in browser)
PUBLIC_ALGOLIA_APP_ID=your_algolia_app_id
PUBLIC_ALGOLIA_SEARCH_KEY=your_algolia_search_key

# Backend API URL (PayloadCMS)
PUBLIC_API_URL=https://nexus-production-8dca.up.railway.app
